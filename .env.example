# ─── Required ─────────────────────────────────────────────────
# DevRev API base URL
DEVREV_API_BASE=https://api.devrev.ai

# Application Access Token — for creating anonymous sessions
DEVREV_AAT=

# Personal Access Token — for admin operations (schema, LLM, config)
DEVREV_PAT=

# Your DevRev org ID (without the DEV- prefix, e.g. "1JpSJovlTT")
DEVREV_DEV_ORG_ID=

# Portal slug (used for default redirect)
DEVREV_PORTAL_SLUG=my-portal

# ─── Auth0 (required if using Auth0 SSO) ─────────────────────
NEXT_PUBLIC_AUTH0_DOMAIN=
NEXT_PUBLIC_AUTH0_CLIENT_ID=
NEXT_PUBLIC_AUTH0_AUDIENCE=janus
NEXT_PUBLIC_REV_AUTH0_ORG_ID=

# ─── Optional ─────────────────────────────────────────────────
# Extended config artifact ID (for AI prompts, layout, styles)
# PORTAL_CONFIG_ARTIFACT_ID=

# Public site URL (for sitemap, canonical URLs, OG tags)
# NEXT_PUBLIC_SITE_URL=https://help.yourcompany.com
